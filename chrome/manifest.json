{
  "manifest_version": 3,
  "name": "Good2Dou",
  "version": "1.14.0",
  "description": "Extract Goodreads metadata and autofill Douban new subject pages.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.goodreads.com/*",
    "*://book.douban.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.goodreads.com/book/show/*",
        "*://*.goodreads.com/*/book/show/*",
        "*://book.douban.com/new_subject*",
        "*://book.douban.com/*/new_subject*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "128": "icon128.png"
  }
}
